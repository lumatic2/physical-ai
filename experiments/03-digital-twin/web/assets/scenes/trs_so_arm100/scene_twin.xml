<mujoco model="so_arm100 twin scene">
  <include file="so_arm100.xml"/>

  <statistic center="0.1 -0.05 0.12" extent="0.55"/>

  <visual>
    <global offwidth="1280" offheight="960" azimuth="135" elevation="-18"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.35 0.35 0.35" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0.3 0 1.5" dir="-0.1 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Target pad: where the policy stacks the blocks (M6 pick-and-place replay).
         Placed inside the arm's reachable band (y<-0.14). Visual only (no collision). -->
    <geom name="pad" type="box" size="0.032 0.032 0.002" pos="0.14 -0.26 0.002"
      rgba="0.95 0.85 0.15 0.65" contype="0" conaffinity="0"/>

    <!-- Pick targets: free-joint blocks so the gripper can lift/stack them.
         Laid out in a row inside the reachable workspace. -->
    <body name="block_a" pos="0.05 -0.18 0.018">
      <freejoint name="block_a_free"/>
      <geom name="block_a" type="box" size="0.018 0.018 0.018" rgba="0.85 0.2 0.2 1"
        mass="0.02" friction="1 0.01 0.0001"/>
    </body>
    <body name="block_b" pos="0.14 -0.18 0.018">
      <freejoint name="block_b_free"/>
      <geom name="block_b" type="box" size="0.018 0.018 0.018" rgba="0.2 0.7 0.3 1"
        mass="0.02" friction="1 0.01 0.0001"/>
    </body>
    <body name="block_c" pos="0.23 -0.18 0.018">
      <freejoint name="block_c_free"/>
      <geom name="block_c" type="box" size="0.018 0.018 0.018" rgba="0.25 0.45 0.9 1"
        mass="0.02" friction="1 0.01 0.0001"/>
    </body>
  </worldbody>

  <!-- Grasp welds (inactive by default). The recorder writes each weld's relpose at the
       grasp instant and toggles eq_active to carry the block; web/desktop replay ignores
       these (kinematic qpos playback). -->
  <equality>
    <weld name="grasp_a" body1="Fixed_Jaw" body2="block_a" active="false"/>
    <weld name="grasp_b" body1="Fixed_Jaw" body2="block_b" active="false"/>
    <weld name="grasp_c" body1="Fixed_Jaw" body2="block_c" active="false"/>
  </equality>
</mujoco>
