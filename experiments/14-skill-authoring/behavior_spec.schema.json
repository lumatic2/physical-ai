{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Physical AI behavior spec",
  "type": "object",
  "required": ["schema_version", "id", "embodiment", "skill", "objective", "target", "constraints", "metrics"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "embodiment": {
      "type": "string",
      "enum": ["g1", "go1", "spot", "barkour"]
    },
    "skill": {
      "type": "string",
      "enum": [
        "pose_hold",
        "squat",
        "front_kick",
        "ball_tap",
        "angled_kick",
        "handstand_prep",
        "reference_motion_track"
      ]
    },
    "level": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"]
    },
    "objective": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hold_pose", "transition_pose", "strike_target", "move_object", "track_reference"]
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": ["max_time_s", "no_fall"],
      "additionalProperties": true,
      "properties": {
        "max_time_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "no_fall": {
          "type": "boolean"
        },
        "min_base_height_m": {
          "type": "number"
        },
        "max_joint_limit_violation": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "fall",
          "base_height",
          "pose_error",
          "transition_time",
          "foot_contact",
          "strike_speed",
          "ball_distance",
          "ball_direction_error",
          "energy",
          "joint_limit_violation",
          "reference_tracking_error"
        ]
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "preferred_method": {
          "type": "string",
          "enum": ["rl", "imitation_then_rl", "scripted_eval_only"]
        },
        "reward_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
